{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:e2e": "PROFILE_DATA_DIR=$(mktemp -d) PORT=3101 tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:integration": "vitest --run src/__tests__/api.spec.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --fix --cache",
    "format": "prettier --write src/",
    "migrate:up": "node scripts/migrate.cjs up",
    "migrate:down": "node scripts/migrate.cjs down",
    "migrate:status": "node scripts/migrate.cjs status"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "migrate-mongo": "^14.0.7",
    "mongoose": "^9.7.0",
    "multer": "^2.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/mongodb": "^12.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.2",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
